@startuml use_case
title AI-Assisted Process Guidance Tool — Use Case Diagram

left to right direction

skinparam usecase {
  BackgroundColor #EEEEFF
  BorderColor #333399
  FontSize 11
}
skinparam actor {
  BackgroundColor #DDEEFF
  BorderColor #2255AA
  FontSize 11
}
skinparam package {
  BackgroundColor #FAFAFA
  BorderColor #AAAAAA
}

actor "Maintenance\nEngineer\n[ME]" as ME
actor "Senior Engineer\n/ SME\n[SME]" as SME
actor "Knowledge\nEngineer\n[KE]" as KE
actor "Supervisor\n[SUP]" as SUP
actor "System\nAdministrator\n[ADM]" as ADM

package "Authentication & User Management" {
  usecase "UC-01: Sign Up" as UC01
  usecase "UC-02: Log In" as UC02
  usecase "UC-03: Log Out" as UC03
  usecase "UC-20: Manage Users & Roles" as UC20
  usecase "UC-21: View Audit Log" as UC21
}

package "Fault Intake & Session Management" {
  usecase "UC-04: Log Fault Issue" as UC04
  usecase "UC-05: Start Diagnostic Session\n[system]" as UC05
  usecase "UC-17: Resume Active Session" as UC17
}

package "AI-Guided Diagnostic Workflow" {
  usecase "UC-06: Conduct Diagnostic\nConversation" as UC06
  usecase "UC-07: Record Measurements" as UC07
  usecase "UC-08: Review Retrieved\nEvidence" as UC08
}

package "Escalation & Expert Review" {
  usecase "UC-09: Escalate Issue to SME" as UC09
  usecase "UC-10: Expert Review by SME" as UC10
  usecase "UC-11: Add Expert Annotation" as UC11
  usecase "UC-12: Flag for Knowledge Review" as UC12
}

package "Reporting & Knowledge Reuse" {
  usecase "UC-13: Generate Fault Report" as UC13
  usecase "UC-14: View Own Session History" as UC14
  usecase "UC-15: View All Sessions" as UC15
  usecase "UC-16: View Escalated Sessions" as UC16
  usecase "UC-18: Review Crane History" as UC18
  usecase "UC-19: View Knowledge Gap Cases" as UC19
}

